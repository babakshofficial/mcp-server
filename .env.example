SYNC_MCP_PROJECT=my-project
SYNC_MCP_STORAGE=sqlite
SYNC_MCP_DATA_DIR=./data
SYNC_MCP_HOST=0.0.0.0
SYNC_MCP_PORT=8080
# JWT signing secret (required in production; >= 32 bytes)
SYNC_MCP_SECRET=change-me-to-a-long-random-string-32b
# Bootstrap first admin when the database has no users
SYNC_MCP_ADMIN_USERNAME=admin
SYNC_MCP_ADMIN_PASSWORD=change-me
# Host path bind-mounted to /repos/AD2 for Docker on_commit git watch (relative to compose file)
# SYNC_MCP_GIT_HOST_PATH=../AD2
# Outbound HTTP(S) proxy for public internet fetches only (LAN/localhost stay direct)
# SYNC_MCP_HTTP_PROXY=http://proxy.corp:8080
# SYNC_MCP_HTTPS_PROXY=http://proxy.corp:8080
# Deprecated: migrated once into an admin API key if set and no keys exist
# SYNC_MCP_TOKEN=

SYNC_MCP_PROJECT=my-project
SYNC_MCP_STORAGE=sqlite
SYNC_MCP_DATA_DIR=./data
SYNC_MCP_HOST=0.0.0.0
SYNC_MCP_PORT=8080
# JWT signing secret (required in production)
SYNC_MCP_SECRET=change-me-to-a-long-random-string
# Bootstrap first admin when the database has no users
SYNC_MCP_ADMIN_USERNAME=admin
SYNC_MCP_ADMIN_PASSWORD=change-me
# Deprecated: migrated once into an admin API key if set and no keys exist
# SYNC_MCP_TOKEN=
